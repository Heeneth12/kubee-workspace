{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "6055b38f-f83a-4bfc-a878-0851fd64561f"
  },
  "newProjectRoot": "projects",
  "projects": {
    "kubee-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/kubee-app",
      "sourceRoot": "projects/kubee-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/kubee-app/src/main.ts",
            "tsConfig": "projects/kubee-app/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/kubee-app/src/assets",
                "output": "/assets/"
              },
              {
                "glob": "**/*",
                "input": "projects/kubee-app/public"
              },
              {
                "glob": "**/*",
                "input": "projects/kubee-ui/src/assets",
                "output": "/assets/"
              }
            ],
            "styles": [
              "projects/kubee-app/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "kubee-app:build:production"
            },
            "development": {
              "buildTarget": "kubee-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
    "kubee-admin": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/kubee-admin",
      "sourceRoot": "projects/kubee-admin/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/kubee-admin/src/main.ts",
            "tsConfig": "projects/kubee-admin/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/kubee-admin/public"
              },
              {
                "glob": "**/*",
                "input": "projects/kubee-ui/src/assets",
                "output": "/assets/"
              }
            ],
            "styles": [
              "projects/kubee-admin/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "kubee-admin:build:production"
            },
            "development": {
              "buildTarget": "kubee-admin:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    },
    "kubee-ui": {
      "projectType": "library",
      "root": "projects/kubee-ui",
      "sourceRoot": "projects/kubee-ui/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/kubee-ui/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/kubee-ui/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/kubee-ui/tsconfig.spec.json"
          }
        }
      }
    }
  }
}